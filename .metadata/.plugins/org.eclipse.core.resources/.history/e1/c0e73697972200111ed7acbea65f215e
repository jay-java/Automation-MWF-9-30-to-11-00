package core;

class User{
	int id;
	String name;
	double value;
	
	User(){
		System.out.println("this is default cons");
	}
	
	User(int i){
		this.id = i;
		System.out.println("i = "+i);
	}
	
	User(int i,int j){
		System.out.println("i = "+i+" j = "+j);
	}
	
	User(int id,String name,double value){
		this.id = id;
		this.name = name;
		this.value = value;
		System.out.println("id = "+id+" name = "+name+" value = "+value);
	}
	
	public void showData() {
		System.out.println("id = "+id+" name = "+name+" value = "+value);
	}
}
public class P012_Constructor {
	public static void main(String[] args) {
		User u = new User();
		
		User u1 = new User(345);
		
		User u2 = new User(12, 34);
		
		User u3 = new User(1, "java", 345.46);
		u3.showData();
		
		User u4 = new User(2, "your name", 4365.4560);
		u4.showData();
	}
}
