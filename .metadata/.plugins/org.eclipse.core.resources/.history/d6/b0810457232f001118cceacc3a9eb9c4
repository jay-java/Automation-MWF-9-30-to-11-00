package core;

class Laptop {
	int ram;
	String model;
	int storage;

	Laptop(int ram, String model, int storage) {
		this.ram = ram;
		this.model = model;
		this.storage = storage;
	}

	@Override
	public String toString() {
		return "Laptop [ram=" + ram + ", model=" + model + ", storage=" + storage + "]";
	}

}

