package core;

import java.util.HashMap;
import java.util.Map;

public class P023_Map {
	public static void main(String[] args) {
		Map<Integer, String> map = new HashMap();
		map.put(1, "c"); // entry
		map.put(2, "c++");
		map.put(3, "java");
		map.put("php", 4);
		map.put(false, 'a');
		map.put(456.456, true);
		map.put(1, "dart");
		System.out.println(map);
		
		
	}
}
