package core;

class Laptop {
	int ram;
	String model;
	int storage;

	Laptop(int ram, String model, int storage) {
		this.ram = ram;
		this.model = model;
		this.storage = storage;
	}

	@Override
	public String toString() {
		return "Laptop [ram=" + ram + ", model=" + model + ", storage=" + storage + "]";
	}

}

public class P021_ListPractical {
	public static void main(String[] args) {
		Laptop l1 = new Laptop(8, "mac", 256);
		Laptop l2 = new Laptop(12, "dell", 512);
		Laptop l3 = new Laptop(16, "lenovo", 1024);
		Laptop l4 = new Laptop(20, "hp", 2048);
		Laptop l5 = new Laptop(24, "asus", 128);
		
	}
}
